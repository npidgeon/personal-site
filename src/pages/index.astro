---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="drawer">
    <input id="my-drawer-3" type="checkbox" class="drawer-toggle" /> 
    <div class="drawer-content flex flex-col">
      
      <!-- Navbar -->
      <nav class="w-full navbar bg-[#2B2D31]/80 backdrop-blur-md sticky top-0 z-50 border-b border-[#1E1F22]/50 shadow-sm">
        <div class="flex-none lg:hidden">
          <label for="my-drawer-3" aria-label="open sidebar" class="btn btn-square btn-ghost text-white">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
          </label>
        </div> 
        <div class="flex-1 px-4 lg:px-8">
          <a href="#" class="text-xl font-bold tracking-tight text-white flex items-center gap-2">
            <span class="text-[#5865F2]">&lt;/&gt;</span>
            pidgeon<span class="text-white/50">.dev</span>
          </a>
        </div>
        <div class="flex-none hidden lg:block">
          <ul class="menu menu-horizontal gap-2 px-4 text-white/80 font-medium">
            <li><a href="#about" class="hover:text-white hover:bg-white/5 transition-colors rounded-lg">About</a></li>
            <li><a href="#resume" class="hover:text-white hover:bg-white/5 transition-colors rounded-lg">Experience</a></li>
            <li><a href="#projects" class="hover:text-white hover:bg-white/5 transition-colors rounded-lg">Projects</a></li>
            <li><a href="#education" class="hover:text-white hover:bg-white/5 transition-colors rounded-lg">Education</a></li>
            <li><a href="#contact" class="btn btn-sm bg-[#5865F2] hover:bg-[#4752C4] border-none text-white ml-2">Get in touch</a></li>
          </ul>
        </div>
      </nav>

      <!-- Main Content -->
      <main class="flex-grow">
        
        <!-- Hero Section -->
        <section id="about" class="min-h-[80vh] flex items-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-[#5865F2]/5 to-transparent z-0"></div>
          <div class="container mx-auto px-6 lg:px-12 relative z-10 py-20">
            <div class="max-w-3xl">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#2B2D31] border border-white/5 mb-6 shadow-sm">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
                </span>
                <span class="text-sm font-medium text-white/70">Employed, but open to connections and opportunities</span>
              </div>
              <h1 class="text-5xl md:text-7xl font-bold text-white tracking-tight mb-6 leading-tight">
                Crafting digital <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#5865F2] to-[#00E5FF]">experiences.</span>
              </h1>
              <p class="text-xl text-white/60 mb-10 max-w-2xl leading-relaxed">
                I'm an aspiring software engineer with a background in IT and Salesforce administration, specializing in building exceptional, high-quality websites and applications that are both beautiful and robust.
              </p>
              <div class="flex flex-wrap gap-4">
                <a href="#projects" class="btn bg-[#5865F2] hover:bg-[#4752C4] border-none text-white px-8 rounded-lg shadow-lg shadow-[#5865F2]/25 transition-all hover:-translate-y-0.5">
                  View Work
                </a>
                <a href="https://github.com/npidgeon" target="_blank" class="btn bg-[#2B2D31] hover:bg-[#1E1F22] border border-white/10 text-white rounded-lg transition-all hover:-translate-y-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
                  GitHub
                </a>
              </div>
            </div>
          </div>
        </section>

        <!-- Resume Section -->
        <section id="resume" class="py-24 bg-[#2B2D31]/30 border-y border-white/5">
          <div class="container mx-auto px-6 lg:px-12">
            <h2 class="text-3xl font-bold text-white mb-12 flex items-center gap-3">
              <span class="text-[#5865F2]">01.</span> Experience
            </h2>
            
            <div class="max-w-4xl">
              <ul class="timeline timeline-snap-icon timeline-compact timeline-vertical">
                <li>
                  <div class="timeline-middle text-[#5865F2]">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  </div>
                  <div class="timeline-end mb-10 group relative pl-6">
                    <div class="absolute -inset-x-4 -inset-y-4 bg-white/0 group-hover:bg-white/5 rounded-2xl transition-all duration-300 z-0"></div>
                    <div class="relative z-10">
                      <time class="font-mono text-sm text-[#5865F2] bg-[#5865F2]/10 px-2 py-1 rounded">June 2022 - Present (Remote)</time>
                      <h3 class="text-xl font-bold text-white mt-2">Director of Enterprise Technology</h3>
                      <div class="text-white/50 text-sm mb-4">Delta Tau Delta Educational Foundation</div>
                      <ul class="text-white/70 leading-relaxed mb-4 list-disc list-outside ml-4 space-y-1">
                        <li>Managed a six-figure IT budget, overseeing hardware, vendors (MSPs/SaaS), and contract negotiations.</li>
                        <li>Led the migration of 600,000+ records to Salesforce NPSP, enhancing reporting and data accessibility.</li>
                        <li>Implemented Salesforce automations, custom API integrations, and managed the GoFundMe Pro integration.</li>
                        <li>Directed data migration from physical servers to SharePoint to improve security and remote collaboration.</li>
                      </ul>
                      <div class="flex flex-wrap gap-2">
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Salesforce Administration</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Data Management</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Workflow Automation</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">IT Strategy</span>
                      </div>
                    </div>
                  </div>
                  <hr class="bg-white/10" />
                </li>
                <li>
                  <hr class="bg-white/10" />
                  <div class="timeline-middle text-white/30">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  </div>
                  <div class="timeline-end mb-10 group relative pl-6">
                    <div class="absolute -inset-x-4 -inset-y-4 bg-white/0 group-hover:bg-white/5 rounded-2xl transition-all duration-300 z-0"></div>
                    <div class="relative z-10">
                      <time class="font-mono text-sm text-white/40">Jun 2020 - Jun 2022 (Remote)</time>
                      <h3 class="text-xl font-bold text-white/90 mt-2">Volunteer Recruitment Coordinator</h3>
                      <div class="text-white/50 text-sm mb-4">Delta Tau Delta International Fraternity</div>
                      <ul class="text-white/60 leading-relaxed mb-4 list-disc list-outside ml-4 space-y-1">
                        <li>Identified, recruited and trained a large base of volunteers. </li>
                        <li>Utilized project management tools and CRMs to manage project pipelines and strong leads.</li>
                        <li>Planned and executed a regional conference with 200+ attendees.</li>
                      </ul>
                      <div class="flex flex-wrap gap-2">
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Targeted Recruiting</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Sales</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Project Management</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Training & Onboarding</span>
                      </div>
                    </div>
                  </div>
                  <hr class="bg-white/10" />
                </li>
                <li>
                  <hr class="bg-white/10" />
                  <div class="timeline-middle text-white/30">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  </div>
                  <div class="timeline-end mb-10 group relative pl-6">
                    <div class="absolute -inset-x-4 -inset-y-4 bg-white/0 group-hover:bg-white/5 rounded-2xl transition-all duration-300 z-0"></div>
                    <div class="relative z-10">
                      <time class="font-mono text-sm text-white/40">Jun 2019 - May 2020 (Hybrid)</time>
                      <h3 class="text-xl font-bold text-white/90 mt-2">Leadership Consultant</h3>
                      <div class="text-white/50 text-sm mb-4">Delta Tau Delta International Fraternity</div>
                      <ul class="text-white/60 leading-relaxed mb-4 list-disc list-outside ml-4 space-y-1">
                        <li>Provided in-person consulting to 17 university branches across 7 states, representing over $2.7M in budgeted revenue.</li>
                        <li>Identified operational gaps and designed actionable improvement plans with branch officers.</li>
                      </ul>
                      <div class="flex flex-wrap gap-2">
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Process Improvement</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Consulting</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Stakeholder Engagement</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Revenue Management</span>
                      </div>
                    </div>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </section>


        <!-- Education Section -->
        <section id="education" class="py-24 border-t border-white/5">
          <div class="container mx-auto px-6 lg:px-12">
            <h2 class="text-3xl font-bold text-white mb-12 flex items-center gap-3">
              <span class="text-[#5865F2]">02.</span> Education
            </h2>
            
            <div class="max-w-4xl">
              <ul class="timeline timeline-snap-icon timeline-compact timeline-vertical">
                <li>
                  <div class="timeline-middle text-[#5865F2]">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  </div>
                  <div class="timeline-end mb-10 group relative pl-6">
                    <div class="absolute -inset-x-4 -inset-y-4 bg-white/0 group-hover:bg-white/5 rounded-2xl transition-all duration-300 z-0"></div>
                    <div class="relative z-10">
                      <time class="font-mono text-sm text-[#5865F2] bg-[#5865F2]/10 px-2 py-1 rounded">Jan 2025 - May 2026</time>
                      <h3 class="text-xl font-bold text-white mt-2">Pathway to Computing Graduate Program</h3>
                      <div class="text-white/50 text-sm mb-4">University of South Florida</div>
                      <div class="flex flex-wrap gap-2 mt-4">
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Computing Essentials</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Discrete Structures</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Data Structures</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">C Programming Essentials</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Computer Systems Essentials</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Object-Oriented Programming</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Network Essentials</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Algorithms Essentials</span>
                      </div>
                    </div>
                  </div>
                  <hr class="bg-white/10" />
                </li>
                <li>
                  <hr class="bg-white/10" />
                  <div class="timeline-middle text-white/30">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  </div>
                  <div class="timeline-end mb-10 group relative pl-6">
                    <div class="absolute -inset-x-4 -inset-y-4 bg-white/0 group-hover:bg-white/5 rounded-2xl transition-all duration-300 z-0"></div>
                    <div class="relative z-10">
                      <time class="font-mono text-sm text-white/40">Aug 2015 - May 2019</time>
                      <h3 class="text-xl font-bold text-white/90 mt-2">B.S. in Integrative Biology</h3>
                      <div class="text-white/50 text-sm mb-4">University of South Florida</div>
                    </div>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </section>

      </main>

      <!-- Footer -->
      <footer id="contact" class="bg-[#1E1F22] py-12 border-t border-white/5">
        <div class="container mx-auto px-6 lg:px-12 flex flex-col items-center justify-center text-center">
          <h2 class="text-2xl font-bold text-white mb-6">Let's build something together.</h2>
          <a href="mailto:nick@pidgeon.dev" class="text-[#5865F2] hover:text-[#00E5FF] transition-colors text-lg font-medium mb-12">nick@pidgeon.dev</a>
          
          <div class="flex gap-6 mb-8 text-white/40">
            <a href="https://github.com/npidgeon" target="_blank" class="hover:text-white transition-transform hover:-translate-y-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg></a>
            <a href="https://www.linkedin.com/in/nicholas-pidgeon/" target="_blank" class="hover:text-[#0077B5] transition-transform hover:-translate-y-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg></a>
          </div>
          
          <p class="text-white/30 text-sm">© {new Date().getFullYear()} Nick / pidgeon.dev. All rights reserved.</p>
        </div>
      </footer>
      
    </div> 
    <div class="drawer-side z-[60]">
      <label for="my-drawer-3" aria-label="close sidebar" class="drawer-overlay"></label> 
      <ul class="menu p-4 w-80 min-h-full bg-[#1E1F22] text-white/80 gap-2 border-r border-white/5">
        <li class="mb-4">
          <a href="#" class="text-xl font-bold tracking-tight text-white flex items-center gap-2">
            <span class="text-[#5865F2]">&lt;/&gt;</span>
            pidgeon<span class="text-white/50">.dev</span>
          </a>
        </li>
        <li><a href="#about" class="hover:text-white hover:bg-white/5">About</a></li>
        <li><a href="#resume" class="hover:text-white hover:bg-white/5">Experience</a></li>
        <li><a href="#projects" class="hover:text-white hover:bg-white/5">Projects</a></li>
        <li><a href="#education" class="hover:text-white hover:bg-white/5">Education</a></li>
        <li class="mt-4"><a href="#contact" class="btn btn-sm bg-[#5865F2] hover:bg-[#4752C4] border-none text-white w-full">Get in touch</a></li>
      </ul>
    </div>
  </div>
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
