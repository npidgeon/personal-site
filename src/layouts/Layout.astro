---
import "../assets/app.css";

const title = "Nick Pidgeon | Salesforce Administrator & Developer";
const description = "Salesforce administrator and developer based in Tampa Bay specializing in Salesforce, data systems, and full-stack development. Currently completing USF's Pathway to Computing graduate program.";
const url = "https://pidgeon.dev";
const image = `${url}/og-image.png`;
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">

		<!-- Primary Meta -->
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Nick Pidgeon" />
		<meta name="keywords" content="Nick Pidgeon, Salesforce administrator, Salesforce, data management, Tampa Bay, USF, portfolio, full-stack" />

		<!-- Open Graph (LinkedIn, Facebook, Discord, Slack) -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="pidgeon.dev" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={url} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<!-- Fonts -->
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#313338] text-[#F2F3F5] antialiased page-loading">
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	/* Page load animation — body starts invisible, JS removes .page-loading */
	body.page-loading * {
		animation-play-state: paused !important;
	}
</style>

<script is:inline>
	// Remove loading class once DOM is ready so CSS animations fire in sequence
	document.addEventListener('DOMContentLoaded', () => {
		document.body.classList.remove('page-loading');
	});
</script>
