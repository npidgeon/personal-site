---
---
        <section id="resume" class="py-24 bg-[#2B2D31]/30 border-y border-white/5 section-animate">
          <div class="container mx-auto px-6 lg:px-12">
            <h2 class="text-3xl font-bold text-white mb-12 flex items-center gap-3">
              <span class="text-[#5865F2]">01.</span> Experience
            </h2>
            
            <div class="max-w-4xl">
              <ul class="timeline timeline-snap-icon timeline-compact timeline-vertical">
                <li>
                  <div class="timeline-middle text-[#5865F2]">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  </div>
                  <div class="timeline-end mb-10 group relative pl-6">
                    <div class="absolute -inset-x-4 -inset-y-4 bg-white/0 group-hover:bg-white/5 rounded-2xl transition-all duration-300 z-0"></div>
                    <div class="relative z-10">
                      <time class="font-mono text-sm text-[#5865F2] bg-[#5865F2]/10 px-2 py-1 rounded">June 2022 - Present (Remote)</time>
                      <div class="flex items-center gap-2 mt-2">
                        <h3 class="text-xl font-bold text-white">Director of Enterprise Technology</h3>
                        <button class="entry-toggle ml-1 text-white/30 hover:text-white/70 transition-colors flex-shrink-0" aria-label="Toggle details" aria-expanded="false">
                          <svg class="chevron w-4 h-4 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
                        </button>
                      </div>
                      <div class="text-white/60 text-sm mb-3">Delta Tau Delta Educational Foundation</div>
                      <div class="entry-body">
                        <ul class="text-white/70 leading-relaxed mb-4 list-disc list-outside ml-4 space-y-1">
                          <li>Created and managed a six-figure IT budget, overseeing hardware procurement, vendor relationships, and contract negotiations.</li>
                          <li>Led the successful migration of 600,000+ constituent and donation records from two legacy CRMs to Salesforce NPSP.</li>
                          <li>Developed and maintained automations, custom objects and fields, and Apex REST APIs to fully leverage Salesforce data and integrate with external systems.</li>
                          <li>Developed and implemented a prospect scoring engine in Salesforce using DLRS and Flows to identify high-value prospects for fundraising.</li>
                          <li>Oversaw the migration of four on-prem file servers to SharePoint to improve security and remote collaboration.</li>
                          <li>Worked with external MSP to manage network infrastructure, cybersecurity policies, and employee onboarding/offboarding.</li>
                          <li>Trained new employees on IT policies, Salesforce best practices, and other internal platforms.</li>
                          <li>Created and maintained documentation for IT policies, standard operating procedures, and Salesforce best practices.</li>
                          <li>Managed all technical aspects of Account Engagement email platform, including list segmentation, automation, and deliverability/domain management.</li>
                        </ul>
                      </div>
                      <div class="flex flex-wrap gap-2">
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Salesforce Administration</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Data Management</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Workflow Automation</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">IT Strategy</span>
                      </div>
                    </div>
                  </div>
                  <hr class="bg-white/10" />
                </li>
                <li>
                  <hr class="bg-white/10" />
                  <div class="timeline-middle text-white/30">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  </div>
                  <div class="timeline-end mb-10 group relative pl-6">
                    <div class="absolute -inset-x-4 -inset-y-4 bg-white/0 group-hover:bg-white/5 rounded-2xl transition-all duration-300 z-0"></div>
                    <div class="relative z-10">
                      <time class="font-mono text-sm text-white/50">Jun 2020 - Jun 2022 (Remote)</time>
                      <div class="flex items-center gap-2 mt-2">
                        <h3 class="text-xl font-bold text-white/90">Volunteer Recruitment Coordinator</h3>
                        <button class="entry-toggle ml-1 text-white/30 hover:text-white/70 transition-colors flex-shrink-0" aria-label="Toggle details" aria-expanded="false">
                          <svg class="chevron w-4 h-4 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
                        </button>
                      </div>
                      <div class="text-white/60 text-sm mb-3">Delta Tau Delta International Fraternity</div>
                      <div class="entry-body">
                        <ul class="text-white/60 leading-relaxed mb-4 list-disc list-outside ml-4 space-y-1">
                          <li>Identified, recruited and trained a large base of volunteers. </li>
                          <li>Utilized project management tools and CRMs to manage project pipelines and strong leads.</li>
                          <li>Planned and executed a regional conference with 200+ attendees.</li>
                        </ul>
                      </div>
                      <div class="flex flex-wrap gap-2">
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Targeted Recruiting</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Sales</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Project Management</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Training & Onboarding</span>
                      </div>
                    </div>
                  </div>
                  <hr class="bg-white/10" />
                </li>
                <li>
                  <hr class="bg-white/10" />
                  <div class="timeline-middle text-white/30">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  </div>
                  <div class="timeline-end mb-10 group relative pl-6">
                    <div class="absolute -inset-x-4 -inset-y-4 bg-white/0 group-hover:bg-white/5 rounded-2xl transition-all duration-300 z-0"></div>
                    <div class="relative z-10">
                      <time class="font-mono text-sm text-white/50">Jun 2019 - May 2020 (Hybrid)</time>
                      <div class="flex items-center gap-2 mt-2">
                        <h3 class="text-xl font-bold text-white/90">Leadership Consultant</h3>
                        <button class="entry-toggle ml-1 text-white/30 hover:text-white/70 transition-colors flex-shrink-0" aria-label="Toggle details" aria-expanded="false">
                          <svg class="chevron w-4 h-4 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
                        </button>
                      </div>
                      <div class="text-white/60 text-sm mb-3">Delta Tau Delta International Fraternity</div>
                      <div class="entry-body">
                        <ul class="text-white/60 leading-relaxed mb-4 list-disc list-outside ml-4 space-y-1">
                          <li>Provided in-person consulting to 17 university branches across 7 states, representing over $2.7M in budgeted revenue.</li>
                          <li>Identified operational gaps and designed actionable improvement plans with branch officers.</li>
                        </ul>
                      </div>
                      <div class="flex flex-wrap gap-2">
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Process Improvement</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Consulting</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Stakeholder Engagement</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Revenue Management</span>
                      </div>
                    </div>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </section>

<script>
  // Collapsible entry bodies — shared logic for Experience & Education
  document.querySelectorAll<HTMLButtonElement>('.entry-toggle').forEach((btn) => {
    const body = btn.closest('.relative.z-10')?.querySelector<HTMLElement>('.entry-body');
    const chevron = btn.querySelector<SVGElement>('.chevron');
    if (!body) return;

    // Collapsed by default
    body.style.maxHeight = '0px';
    body.style.overflow = 'hidden';
    body.style.transition = 'max-height 0.4s cubic-bezier(0.22, 1, 0.36, 1)';

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        body.style.maxHeight = '0px';
        btn.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.style.transform = 'rotate(0deg)';
      } else {
        body.style.maxHeight = body.scrollHeight + 'px';
        btn.setAttribute('aria-expanded', 'true');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
