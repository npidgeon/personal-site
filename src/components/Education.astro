---
---
        <section id="education" class="py-24 border-t border-white/5">
          <div class="container mx-auto px-6 lg:px-12">
            <h2 class="text-3xl font-bold text-white mb-12 flex items-center gap-3">
              <span class="text-[#5865F2]">02.</span> Education
            </h2>
            
            <div class="max-w-4xl">
              <ul class="timeline timeline-snap-icon timeline-compact timeline-vertical">
                <li>
                  <div class="timeline-middle text-[#5865F2]">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  </div>
                  <div class="timeline-end mb-10 group relative pl-6">
                    <div class="absolute -inset-x-4 -inset-y-4 bg-white/0 group-hover:bg-white/5 rounded-2xl transition-all duration-300 z-0"></div>
                    <div class="relative z-10">
                      <time class="font-mono text-sm text-[#5865F2] bg-[#5865F2]/10 px-2 py-1 rounded">Jan 2025 - May 2026</time>
                      <h3 class="text-xl font-bold text-white mt-2">Pathway to Computing Graduate Program</h3>
                      <div class="text-white/50 text-sm mb-4">University of South Florida</div>
                      <ul class="text-white/60 leading-relaxed mb-4 list-disc list-outside ml-4 space-y-1">
                        <li>Pathway to Computing is USF's intensive 8-course bridge program, designed to cover all fundamental topics of computer science and prepare students for graduate studies or a career shift.</li>
                        <li>Courses are a mix of theory and practical application, with a strong emphasis on hands-on projects and assignments.</li>
                        <li>After graduating, students receive priority admission to USF's Master of Science in Computer Science, Cybersecurity, Computer Engineering, or Artificial Intelligence programs.</li>
                      </ul>
                      <div class="flex flex-wrap gap-2 mt-4">
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Computing Essentials</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Discrete Structures</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Data Structures</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20 inline-flex items-center gap-1" title="Favorite Course">
                          C Programming Essentials
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-amber-400"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>
                        </span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20 inline-flex items-center gap-1" title="Favorite Course">
                          Computer Systems Essentials
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 text-amber-400"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>
                        </span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Object-Oriented Programming</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Network Essentials</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Algorithms Essentials</span>
                      </div>
                    </div>
                  </div>
                  <hr class="bg-white/10" />
                </li>
                <li>
                  <hr class="bg-white/10" />
                  <div class="timeline-middle text-white/30">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                  </div>
                  <div class="timeline-end mb-10 group relative pl-6">
                    <div class="absolute -inset-x-4 -inset-y-4 bg-white/0 group-hover:bg-white/5 rounded-2xl transition-all duration-300 z-0"></div>
                    <div class="relative z-10">
                      <time class="font-mono text-sm text-white/40">Aug 2015 - May 2019</time>
                      <h3 class="text-xl font-bold text-white/90 mt-2">B.S. in Integrative Biology</h3>
                      <div class="text-white/50 text-sm mb-4">University of South Florida</div>
                      <div class="flex flex-wrap gap-2 mt-4">
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Organic Chemistry I & II</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Calculus</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Statistics</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Principles of Immunology</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Human Anatomy and Physiology I & II</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">General Genetics</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Medical and Applied Entomology</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">General Microbiology</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Physics I & II</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Principles of Ecology</span>
                        <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Parasitology</span>
                      </div>
                    </div>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </section>
