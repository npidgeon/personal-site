---
---

<section id="skills" class="py-24 bg-[#2B2D31]/30 border-y border-white/5 section-animate">
  <div class="container mx-auto px-6 lg:px-12">
    <h2 class="text-3xl font-bold text-white mb-12 flex items-center gap-3">
      <span class="text-[#5865F2]">03.</span> Skills
    </h2>

    <div class="max-w-4xl grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Languages & Dev -->
      <div class="skill-card group relative bg-[#1E1F22] border border-white/5 rounded-2xl p-6 hover:border-[#5865F2]/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-[#5865F2]/10">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-lg bg-[#5865F2]/20 flex items-center justify-center text-[#5865F2]">
            <!-- Code icon -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
          </div>
          <h3 class="font-semibold text-white text-sm uppercase tracking-wider">Machine Languages</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="skill-tag">Python</span>
          <span class="skill-tag">C</span>
          <span class="skill-tag">Java</span>
          <span class="skill-tag">JavaScript</span>
          <span class="skill-tag">HTML / CSS</span>
          <span class="skill-tag">SQL</span>
          <span class="skill-tag">Apex</span>
          <span class="skill-tag">SOQL</span>
          <span class="skill-tag">Bash</span>
          <span class="skill-tag">PowerShell</span>
        </div>
      </div>

      <!-- Salesforce Platform -->
      <div class="skill-card group relative bg-[#1E1F22] border border-white/5 rounded-2xl p-6 hover:border-[#5865F2]/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-[#5865F2]/10">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-lg bg-[#5865F2]/20 flex items-center justify-center text-[#5865F2]">
            <!-- Cloud icon -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
            </svg>
          </div>
          <h3 class="font-semibold text-white text-sm uppercase tracking-wider">Salesforce</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="skill-tag">Custom Objects</span>
          <span class="skill-tag">Flows & Automation</span>
          <span class="skill-tag">Apex Classes</span>
          <span class="skill-tag">API Integrations</span>
          <span class="skill-tag">Data Migration</span>
          <span class="skill-tag">Reports & Dashboards</span>
          <span class="skill-tag">NPSP</span>
          <span class="skill-tag">Account Engagement</span>
          
        </div>
      </div>

      <!-- Infrastructure & Tools -->
      <div class="skill-card group relative bg-[#1E1F22] border border-white/5 rounded-2xl p-6 hover:border-[#5865F2]/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-[#5865F2]/10">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-lg bg-[#5865F2]/20 flex items-center justify-center text-[#5865F2]">
            <!-- Server icon -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a3 3 0 0 1 3-3m0 0a3 3 0 0 0 3-3V4.5" />
            </svg>
          </div>
          <h3 class="font-semibold text-white text-sm uppercase tracking-wider">Infrastructure</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="skill-tag">Linux (Ubuntu)</span>
          <span class="skill-tag">Docker</span>
          <span class="skill-tag">Git</span>
          <span class="skill-tag">GitHub</span>
          <span class="skill-tag">Server Administration</span>
          <span class="skill-tag">AWS S3</span>
          <span class="skill-tag">Microsoft 365</span>
        </div>
      </div>

      <!-- Web & Software -->
      <div class="skill-card group relative bg-[#1E1F22] border border-white/5 rounded-2xl p-6 hover:border-[#5865F2]/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-[#5865F2]/10">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-lg bg-[#5865F2]/20 flex items-center justify-center text-[#5865F2]">
            <!-- Globe icon -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <h3 class="font-semibold text-white text-sm uppercase tracking-wider">Web & Software</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="skill-tag">Astro</span>
          <span class="skill-tag">React</span>
          <span class="skill-tag">Node.js</span>
          <span class="skill-tag">REST APIs</span>
          <span class="skill-tag">Tailwind CSS</span>
          <span class="skill-tag">AWS</span>
          <span class="skill-tag">Cloudflare</span>
        </div>
      </div>

      <!-- Soft Skills & Other -->
      <div class="skill-card group relative bg-[#1E1F22] border border-white/5 rounded-2xl p-6 hover:border-[#5865F2]/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-[#5865F2]/10">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-lg bg-[#5865F2]/20 flex items-center justify-center text-[#5865F2]">
            <!-- User group icon -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            </svg>
          </div>
          <h3 class="font-semibold text-white text-sm uppercase tracking-wider">Leadership & Comms</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="skill-tag">Stakeholder Management</span>
          <span class="skill-tag">Technical Writing</span>
          <span class="skill-tag">Training & Onboarding</span>
          <span class="skill-tag">Project Management</span>
          <span class="skill-tag">Budget Development</span>
        </div>
      </div>

      <!-- Languages Spoken -->
      <div class="skill-card group relative bg-[#1E1F22] border border-white/5 rounded-2xl p-6 hover:border-[#5865F2]/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-[#5865F2]/10">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-lg bg-[#5865F2]/20 flex items-center justify-center text-[#5865F2]">
            <!-- Chat bubble icon -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
            </svg>
          </div>
          <h3 class="font-semibold text-white text-sm uppercase tracking-wider">Human Languages</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="skill-tag inline-flex items-center gap-1">
            English
            <span class="text-[10px] text-white/40 font-normal">Native</span>
          </span>
          <span class="skill-tag inline-flex items-center gap-1">
            Spanish
            <span class="text-[10px] text-white/40 font-normal">Fluent</span>
          </span>
          <span class="skill-tag inline-flex items-center gap-1">
            German
            <span class="text-[10px] text-white/40 font-normal">A2</span>
          </span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .skill-tag {
    font-size: 0.7rem;
    font-family: ui-monospace, monospace;
    color: #b5bac1;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .skill-card:hover .skill-tag {
    color: #00E5FF;
    border-color: rgba(0,229,255,0.2);
    background: rgba(0,229,255,0.05);
  }
</style>
