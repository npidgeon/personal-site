---
---
<section id="projects" class="py-24 border-t border-white/5 section-animate">
  <div class="container mx-auto px-6 lg:px-12">
    <h2 class="text-3xl font-bold text-white mb-12 flex items-center gap-3">
      <span class="text-[#5865F2]">02.</span> Projects
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl">

      <a href="https://github.com/npidgeon/Simple-Anonymized-Heatmap" target="_blank" class="group block relative rounded-2xl overflow-hidden bg-[#2B2D31]/50 border border-white/5 hover:border-[#5865F2]/50 hover:shadow-lg hover:shadow-[#5865F2]/10 transition-all duration-300 transform hover:-translate-y-1">
        <div class="aspect-video w-full overflow-hidden bg-[#1E1F22]">
          <img src="/heatmap.png" alt="Anonymized Heatmap Tool" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
        </div>
        <div class="p-6">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold text-white group-hover:text-[#5865F2] transition-colors">Simple Anonymized Heatmap</h3>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-[#5865F2] transition-colors"><path d="M15 3h6v6"></path><path d="M10 14L21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg>
          </div>
          <p class="text-white/60 text-sm leading-relaxed mb-6">
            A privacy-focused Python web application that dynamically jitters coordinate datasets to protect user anonymity while retaining geographic density patterns. Supports interactive modification and data fetching from AWS S3 buckets.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Python</span>
            <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Streamlit</span>
            <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Pandas</span>
            <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Geopandas</span>
          </div>
        </div>
      </a>

      <a href="https://github.com/npidgeon/personal-site" target="_blank" class="group block relative rounded-2xl overflow-hidden bg-[#2B2D31]/50 border border-white/5 hover:border-[#5865F2]/50 hover:shadow-lg hover:shadow-[#5865F2]/10 transition-all duration-300 transform hover:-translate-y-1">
        <div class="aspect-video w-full overflow-hidden bg-[#1E1F22]">
           <img src="/portfolio.png" alt="Developer Portfolio Website" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
        </div>
        <div class="p-6">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold text-white group-hover:text-[#5865F2] transition-colors">Developer Portfolio</h3>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-[#5865F2] transition-colors"><path d="M15 3h6v6"></path><path d="M10 14L21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg>
          </div>
          <p class="text-white/60 text-sm leading-relaxed mb-6">
            A lightning-fast, highly optimized personal website constructed with Astro. Features a custom interactive terminal widget using pure vanilla Javascript to emulate bash commands, paired with elegant and responsive styling via Tailwind.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Astro</span>
            <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Tailwind CSS</span>
            <span class="text-xs font-mono text-[#00E5FF] bg-[#00E5FF]/10 px-2 py-1 rounded border border-[#00E5FF]/20">Vanilla JS</span>
          </div>
        </div>
      </a>
      
    </div>
  </div>
</section>
